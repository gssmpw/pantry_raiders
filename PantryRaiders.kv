#:import Color kivy.graphics.Color
#:import Rectangle kivy.graphics.Rectangle
#:import RoundedRectangle kivy.graphics.RoundedRectangle

# RootWidget holds the ScreenManager
<RootWidget>:
    ScreenManager:
        LoginScreen:
            name: "login"
        HomeScreen:
            name: "home"
        PantryScreen:
            name: "pantry"
        ListScreen:
            name: "list"
        ScanOptionsScreen:
            name: "scanOptions"
        ScanPictureScreen:
            name: "scanPicture"
        ScanReceiptScreen:
            name: "scanReceipt"


<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: [30, 40, 30, 40]
        spacing: 18

        canvas.before:
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20,]
                source:'C:/Users/gsmit/Documents/pantry_raiders/frontendImages/PantryRaidersImage.png'

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "bottom"

            BoxLayout:
                orientation: "vertical"
                spacing: 16
                padding: [24, 24, 24, 24]
                size_hint: (None, None)
                width: min(root.width * 0.55, 520)
                height: min(root.height * 0.45, 400)

                canvas.before:
                    Color:
                        rgba: 0.98, 0.99, 0.94, 0
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [25]

                Label:
                    text: "USERNAME"
                    font_size: min(root.width * 0.014, 40)
                    bold: True
                    color: 0.15, 0.35, 0.22, 1
                    halign: "left"
                    valign: "middle"
                    text_size: self.width, None
                    size_hint: (1, None)
                    height: self.font_size + 18
                TextInput:
                    id: username_input
                    hint_text: "Enter your username"
                    multiline: False
                    font_size: min(root.width * 0.018, 22)
                    padding: [12, 10]
                    size_hint: (1, None)
                    height: self.font_size + 30

                Label:
                    text: "PASSWORD"
                    font_size: min(root.width * 0.014, 40)
                    bold: True
                    color: 0.15, 0.35, 0.22, 1
                    halign: "left"
                    valign: "middle"
                    text_size: self.width, None
                    size_hint: (1, None)
                    height: self.font_size + 18

                BoxLayout:
                    orientation: "horizontal"
                    size_hint: (1, None)
                    height: 45
                    spacing: 8

                    TextInput:
                        id: password_input
                        hint_text: "Enter your password"
                        password: True
                        multiline: False
                        font_size: min(root.width * 0.018, 22)
                        padding: [12, 10]

                    Button:
                        id: toggle_btn
                        text: "Show"
                        size_hint: (None, 1)
                        width: 75
                        font_size: min(root.width * 0.014, 22)
                        background_color: 0.35, 0.18, 0.05, 1
                        on_press: root.toggle_password()

                Label:
                    id: error_label
                    text: ""
                    font_size: min(root.width * 0.014, 13)
                    color: 0.9, 0.1, 0.1, 1
                    size_hint: (1, None)
                    height: 20

                Button:
                    text: "LOG IN"
                    font_size: min(root.width * 0.018, 40)
                    bold: True
                    size_hint: (1, None)
                    height: self.font_size + 28
                    background_color: 0.08, 0.25, 0.16, 1
                    on_press: root.validate_login()


<HomeScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.96, 0.98, 0.88, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20,]

        Label:
            text: "Welcome to Pantry Raiders!"
            font_size: 75
            bold: True
            color: 0.10, 0.30, 0.16, 1
            size_hint: (1, 0.25)
            pos_hint: {"center_x": 0.5}

        Button:
            size_hint: (0.75, 0.18)
            pos_hint: {"center_x": 0.5}
            background_normal:'C:/Users/gsmit/Documents/pantry_raiders/frontendImages/ViewPantryImage.png'
            background_stretch: False
            background_tile: False
            on_press: root.go_to_pantry()

        Button:
            background_normal:'C:/Users/gsmit/Documents/pantry_raiders/frontendImages/GroceryListImage.png'
            size_hint: (0.75, 0.18)
            pos_hint: {"center_x": 0.5}
            background_stretch: False
            background_tile: False
            on_press: root.go_to_list()

        Button:
            background_normal:'C:/Users/gsmit/Documents/pantry_raiders/frontendImages/ScanItemsImage.png'
            size_hint: (0.75, 0.18)
            pos_hint: {"center_x": 0.5}
            background_stretch: True
            background_tile: False
            on_press: root.go_to_scanOptions()


<PantryScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 18

        canvas.before:
            Color:
                rgba: 0.90, 0.97, 0.90, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            id: result_label
            text: "Pantry Inventory"
            font_size: 28
            bold: True
            color: 0.08, 0.30, 0.15, 1

        Button:
            text: "Refresh Pantry"
            font_size: 20
            bold: True
            background_color: 0.16, 0.58, 0.31, 1
            size_hint: (1, 0.18)
            on_press: root.on_button_press()

        Button:
            text: "Go Back"
            font_size: 18
            background_color: 0.45, 0.45, 0.45, 1
            size_hint: (1, 0.16)
            on_press: root.go_back()


<ListScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 18

        canvas.before:
            Color:
                rgba: 0.91, 0.95, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            id: result_label
            text: "Grocery List"
            font_size: 30
            bold: True
            color: 0.10, 0.25, 0.55, 1

        Button:
            text: "Show Grocery List"
            font_size: 20
            bold: True
            background_color: 0.15, 0.42, 0.78, 1
            size_hint: (1, 0.18)
            on_press: root.on_button_press()

        Button:
            text: "Go Back"
            font_size: 18
            background_color: 0.45, 0.45, 0.45, 1
            size_hint: (1, 0.16)
            on_press: root.go_back()


<ScanOptionsScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 18

        canvas.before:
            Color:
                rgba: 1, 0.95, 0.86, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            id: result_label
            text: "Choose What to Scan"
            font_size: 30
            bold: True
            color: 0.50, 0.25, 0.05, 1

        Button:
            text: "Picture of Your Pantry"
            font_size: 20
            bold: True
            background_color: 0.95, 0.55, 0.18, 1
            size_hint: (1, 0.18)
            on_press: root.picture_button_press()

        Button:
            text: "Picture of Receipt"
            font_size: 20
            bold: True
            background_color: 0.70, 0.35, 0.85, 1
            size_hint: (1, 0.18)
            on_press: root.receipt_button_press()

        Button:
            text: "Go Back"
            font_size: 18
            background_color: 0.45, 0.45, 0.45, 1
            size_hint: (1, 0.16)
            on_press: root.go_back()


<ScanPictureScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 18

        canvas.before:
            Color:
                rgba: 0.92, 0.98, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Image:
            id: camera_feed
            size_hint: (1, 0.55)

        Label:
            id: result_label
            text: "Take a Picture of Your Pantry"
            font_size: 28
            bold: True
            color: 0.08, 0.30, 0.15, 1
            size_hint: (1, 0.15)

        Button:
            text: "Take Picture"
            font_size: 22
            bold: True
            background_color: 0.16, 0.58, 0.31, 1
            size_hint: (1, 0.15)
            on_press: root.on_button_press()

        Button:
            text: "Go Back"
            font_size: 18
            background_color: 0.45, 0.45, 0.45, 1
            size_hint: (1, 0.15)
            on_press: root.go_back()


<ScanReceiptScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 18

        canvas.before:
            Color:
                rgba: 0.98, 0.93, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            id: result_label
            text: "Take a Picture of Your Receipt"
            font_size: 28
            bold: True
            color: 0.35, 0.10, 0.48, 1

        Button:
            text: "Take Picture"
            font_size: 22
            bold: True
            background_color: 0.70, 0.35, 0.85, 1
            size_hint: (1, 0.18)
            on_press: root.on_button_press()

        Button:
            text: "Go Back"
            font_size: 18
            background_color: 0.45, 0.45, 0.45, 1
            size_hint: (1, 0.16)
            on_press: root.go_back()
